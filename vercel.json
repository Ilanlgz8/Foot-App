{
  "rewrites": [
    { "source": "/news",           "destination": "/api/news" },
    { "source": "/espn",           "destination": "/api/espn" },
    { "source": "/sofascore",      "destination": "/api/sofascore" },
    { "source": "/apifootball",    "destination": "/api/apifootball" },
    { "source": "/api/fifa-live",     "destination": "/api/fifa-live" },
    { "source": "/api/fifa-lineups", "destination": "/api/fifa-lineups" },
    { "source": "/api/cron/goals",   "destination": "/api/cron/goals" },
    { "source": "/api/subscribe",    "destination": "/api/subscribe" },
    { "source": "/api/push",         "destination": "/api/push" },
    { "source": "/api/vapid-key",    "destination": "/api/vapid-key" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "DENY" },
        { "key": "X-XSS-Protection",       "value": "1; mode=block" }
      ]
    }
  ]
}
