{
  "functions": {
    "api/cron-goals.js": { "maxDuration": 30 }
  },
  "rewrites": [
    { "source": "/news",           "destination": "/api/news" },
    { "source": "/espn",           "destination": "/api/espn" },
    { "source": "/apifootball",    "destination": "/api/apifootball" },
    { "source": "/api/fifa-live",     "destination": "/api/fifa-live" },
    { "source": "/api/fifa-lineups", "destination": "/api/fifa-lineups" },
    { "source": "/cron-goals",        "destination": "/api/cron-goals" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "DENY" },
        { "key": "X-XSS-Protection",       "value": "1; mode=block" }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/manifest.webmanifest",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
      ]
    }
  ]
}

